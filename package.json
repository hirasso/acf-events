{
  "name": "acf-events",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "author": "Rasso Hilber <mail@rassohilber.com>",
  "scripts": {
    "prepare": "husky",
    "make-pot": "tools/make-pot.sh",
    "version": "pnpm changeset version && tools/cli/cli.js version:patch",
    "wp-env": "wp-env",
    "wp-env-test": "wp-env --config=.wp-env.test.json",
    "wp-env:cli": "wp-env run cli --env-cwd=wp-content/plugins/acf-events",
    "wp-env-test:cli": "pnpm wp-env-test run cli --env-cwd=wp-content/plugins/acf-events",
    "wp-env:open": "open $(wp-env status --json | jq -r '.urls.development')",
    "wp-env-test:open": "open $(wp-env --config .wp-env.test.json status --json | jq -r '.urls.development')",
    "test": "pnpm run test:pest && wp-env reset && wp-env start && pnpm run test:e2e",
    "test:pest": "pnpm run wp-env-test:cli vendor/bin/pest --no-coverage",
    "test:pest:ci": "pnpm run wp-env-test:cli vendor/bin/pest --coverage-clover coverage.xml",
    "test:e2e": "pnpm exec playwright test --config ./tests/E2E/playwright.config.ts",
    "test:e2e:dev": "PLAYWRIGHT_ENV=dev pnpm test:e2e --ui",
    "test:e2e:install": "pnpm exec playwright install --with-deps"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "@wordpress/env": "^11.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0"
  }
}
