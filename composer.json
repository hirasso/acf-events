{
  "name": "hirasso/acf-events",
  "description": "A Composer library to manage events, recurrences and locations using WordPress+Advanced Custom Fields 📆",
  "license": "GPL-2.0-or-later",
  "authors": [
    {
      "name": "Rasso Hilber",
      "email": "mail@rassohilber.com",
      "homepage": "https://rassohilber.com"
    }
  ],
  "require": {
    "php": ">=8.2",
    "illuminate/collections": "^11 || ^12"
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "autoload": {
    "psr-4": {
      "Hirasso\\ACFEvents\\": [
        "src/ACFEvents"
      ]
    },
    "files": [
      "src/helpers.php"
    ]
  },
  "scripts": {
    "format": "vendor/bin/mago format",
    "lint": "vendor/bin/mago lint",
    "analyse": "vendor/bin/mago analyse"
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true,
    "allow-plugins": {
      "composer/installers": true,
      "roots/wordpress-core-installer": true
    }
  },
  "extra": {
    "installer-paths": {
      "vendor/.wp/mu-plugins/{$name}/": [
        "type:wordpress-muplugin"
      ],
      "vendor/.wp/plugins/{$name}/": [
        "type:wordpress-plugin"
      ],
      "vendor/.wp/themes/{$name}/": [
        "type:wordpress-theme"
      ]
    },
    "wordpress-install-dir": "vendor/.wp/core"
  },
  "repositories": {
    "wpackagist": {
      "type": "composer",
      "url": "https://wpackagist.org",
      "only": [
        "wpackagist-plugin/*",
        "wpackagist-theme/*"
      ]
    }
  },
  "require-dev": {
    "carthage-software/mago": "^1.13",
    "roots/wordpress": "^6.9",
    "wpackagist-plugin/advanced-custom-fields": "^6.7",
    "wpackagist-plugin/classic-editor": "^1.6",
    "wpackagist-plugin/polylang": "^3.7"
  }
}
