{
  "$schema": "https://schemas.wp.org/trunk/wp-env.json",
  "phpVersion": "8.3",
  "core": "./vendor/.wp/core",
  "themes": ["./vendor/.wp/themes/twentytwentyfive"],
  "plugins": [
    "./vendor/.wp/plugins/advanced-custom-fields",
    "./vendor/.wp/plugins/classic-editor",
    "./vendor/.wp/plugins/sg-security",
    "./tests/E2E"
  ],
  "env": {
    "development": {
      "port": 2233,
      "config": {
        "RHAU_WP_ENV": "development"
      }
    },
    "tests": {
      "port": 22333,
      "config": {
        "WP_DEBUG": true,
        "RHAU_WP_ENV": "tests"
      },
      "mappings": {
        "wp-content/mu-plugins": "./packages/e2e-tests/mu-plugins"
      }
    }
  },
  "lifecycleScripts": {
    "afterStart": "./tools/wp-env-after-start.sh"
  }
}
